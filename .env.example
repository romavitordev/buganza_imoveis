# ============================================================
# Buganza Imóveis — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# ============================================================

# Postgres (recomendado: Neon — https://neon.tech, plano gratuito)
# Formato: postgresql://usuario:senha@host/banco?sslmode=require
DATABASE_URL="postgresql://user:password@host.neon.tech/buganza?sslmode=require"

# Segredo do JWT da sessão do admin (obrigatório — o app não sobe sem ele).
# Gere um valor forte, ex.: `openssl rand -base64 32`
AUTH_SECRET=""

# Supabase Storage (bucket público "imoveis") — usado para as fotos.
# Em desenvolvimento, se deixar vazio, o upload cai em public/uploads (NÃO funciona na Vercel).
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Credenciais do admin criadas pelo seed (npm run db:seed)
ADMIN_EMAIL="imoveisbuganza@gmail.com"
ADMIN_PASSWORD="admin123"

# Número do WhatsApp que recebe os contatos (só dígitos: 55 + DDD + número).
# Número oficial da Buganza Imóveis: +55 15 99829-6767
NEXT_PUBLIC_WHATSAPP_NUMBER="5515998296767"

# URL pública do site em produção (usada em sitemap, robots e Open Graph)
NEXT_PUBLIC_SITE_URL="https://www.buganzaimoveis.com.br"
