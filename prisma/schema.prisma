// Schema do banco — Buganza Imóveis
//
// Para desenvolvimento local SEM Postgres, dá para trocar para SQLite,
// mas atenção — o Prisma NÃO suporta enums em SQLite, então a troca exige:
//   1. Em `datasource db`, mude `provider = "postgresql"` para `provider = "sqlite"`
//   2. No .env, use: DATABASE_URL="file:./dev.db"
//   3. Remova as anotações exclusivas de Postgres: `@db.Text` (em Property.descricao)
//      e `@db.Decimal(12, 2)` (em Property.precoInterno)
//   4. Substitua os campos que usam enums (tipo, transacao, status) por `String`
//      e remova os blocos `enum` — os valores continuam os mesmos em runtime
//   5. Rode `npm run db:push` e `npm run db:seed` normalmente
// Recomendação: prefira um Postgres gratuito no Neon (https://neon.tech) —
// leva 2 minutos e evita essas alterações.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoImovel {
  RESIDENCIAL
  COMERCIAL
  TERRENO
}

enum Transacao {
  VENDA
  LOCACAO
  VENDA_LOCACAO
}

enum StatusImovel {
  ATIVO
  PAUSADO
  VENDIDO
  ALUGADO
}

enum TipoEvento {
  VISUALIZACAO
  CLIQUE_WHATSAPP
}

model AdminUser {
  id           String   @id @default(cuid())
  nome         String
  email        String   @unique
  passwordHash String
  criadoEm     DateTime @default(now())
}

model Property {
  id           String       @id @default(cuid())
  codigo       String       @unique
  slug         String       @unique
  titulo       String
  descricao    String       @db.Text
  tipo         TipoImovel
  transacao    Transacao
  status       StatusImovel @default(ATIVO)
  destaque     Boolean      @default(false)

  cidade       String
  bairro       String

  quartos      Int?
  banheiros    Int?
  vagas        Int?
  areaM2       Int?

  // Preços PÚBLICOS — exibidos no site (cards e detalhe).
  // Ausente = "Sob consulta".
  precoVenda   Decimal?     @db.Decimal(12, 2)
  precoLocacao Decimal?     @db.Decimal(12, 2)

  // Preço para organização interna do casal — NUNCA aparece no site público.
  // A allowlist de lib/dto.ts garante que este campo jamais é serializado
  // em respostas de rotas públicas.
  precoInterno Decimal?     @db.Decimal(12, 2)

  // Vídeo do imóvel — aparece SÓ na página de detalhe, abaixo da galeria.
  // Nunca é usado como capa do card nem nos destaques.
  videoUrl        String?
  videoStorageKey String?

  fotos        PropertyPhoto[]
  eventos      PropertyEvent[]
  criadoEm     DateTime     @default(now())
  atualizadoEm DateTime     @updatedAt

  @@index([status, destaque])
  @@index([tipo, transacao, cidade])
}

// Eventos de analytics do site público: visualizações da página do imóvel
// e cliques nos botões de WhatsApp. Alimentam as métricas do dashboard.
//
// LGPD: nenhum dado pessoal cru é armazenado. `dedupeHash` é um SHA-256 de
// IP+navegador usado apenas para não contar o mesmo dispositivo duas vezes
// no mesmo dia — o IP em si nunca é gravado.
model PropertyEvent {
  id          String     @id @default(cuid())
  property    Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId  String
  tipo        TipoEvento
  // Contexto anônimo do acesso
  dispositivo String? // MOBILE | DESKTOP | TABLET
  origem      String? // utm_source ou domínio do referrer (ex.: instagram.com)
  dedupeHash  String? // pseudônimo do dispositivo (nunca o IP cru)
  criadoEm    DateTime   @default(now())

  @@index([propertyId, tipo, criadoEm])
  @@index([dedupeHash, tipo, criadoEm])
}

model PropertyPhoto {
  id         String   @id @default(cuid())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
  url        String
  storageKey String
  ordem      Int      @default(0)
  capa       Boolean  @default(false)

  @@index([propertyId, ordem])
}
